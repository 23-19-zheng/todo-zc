# ========================================
# 环境变量配置文件
# 请根据实际情况修改以下配置
# ========================================

# MySQL配置
MYSQL_ROOT_PASSWORD=TodoRoot@2024
MYSQL_PORT=3306

# 数据库用户配置
DB_USERNAME=todo_user
DB_PASSWORD=TodoUser@2024

# Redis配置
REDIS_PASSWORD=TodoRedis@2024
REDIS_PORT=6379

# 应用端口
APP_PORT=8080

# JWT密钥（生产环境请使用安全随机字符串，至少256位）
JWT_SECRET=todo-app-production-jwt-secret-key-must-be-at-least-256-bits-long-for-security-2024

# JVM参数（根据服务器内存调整）
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC