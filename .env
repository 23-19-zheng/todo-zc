# 环境变量配置文件
# 从 .env.example 复制此文件并修改配置

# ========================================
# MySQL 配置
# ========================================
# MySQL root用户密码（建议修改）
MYSQL_ROOT_PASSWORD=TodoRoot@2024
# MySQL端口（保持默认即可）
MYSQL_PORT=3306

# ========================================
# 数据库用户配置
# ========================================
# 应用使用的数据库用户名
DB_USERNAME=todo_user
# 应用使用的数据库密码（建议修改）
DB_PASSWORD=TodoUser@2024

# ========================================
# Redis 配置
# ========================================
# Redis密码（建议修改）
REDIS_PASSWORD=TodoRedis@2024
# Redis端口（保持默认即可）
REDIS_PORT=6379

# ========================================
# 应用配置
# ========================================
# 应用对外端口
APP_PORT=8080

# JWT密钥（生产环境必须修改！至少256位）
JWT_SECRET=todo-app-production-jwt-secret-key-must-be-at-least-256-bits-long-for-security-2024

# ========================================
# JVM 配置
# ========================================
# JVM参数（根据服务器内存调整）
# 2GB内存服务器: -Xms256m -Xmx512m
# 4GB内存服务器: -Xms512m -Xmx1024m
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC